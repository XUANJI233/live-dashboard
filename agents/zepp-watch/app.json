{
  "configVersion": "v3",
  "app": {
    "appType": "app",
    "version": {
      "code": 1,
      "name": "0.1.0"
    },
    "appId": 10001,
    "appName": "Live Watch",
    "icon": "icon.png",
    "vender": "zepp",
    "description": "Watch health data sync agent for Live Dashboard"
  },
  "runtime": {
    "apiVersion": {
      "compatible": "4.0",
      "target": "4.0",
      "minVersion": "4.0"
    }
  },
  "targets": {
    "gt": {
      "module": {
        "page": {
          "pages": ["page/index"]
        },
        "app-service": {
          "services": ["app-service/live-watch"]
        },
        "app-side": {
          "path": "side-service"
        }
      },
      "platforms": [
        { "st": "r", "dw": 480 },
        { "st": "s", "dw": 390 }
      ],
      "designWidth": 480
    }
  },
  "permissions": [
    "device:os.alarm",
    "device:os.timer",
    "device:os.network",
    "device:os.bg_service",
    "data:user.hd.heart_rate",
    "data:user.hd.step"
  ],
  "i18n": {
    "en-US": {
      "name": "Live Watch"
    },
    "zh-CN": {
      "name": "Live 手表"
    }
  },
  "defaultLanguage": "zh-CN"
}