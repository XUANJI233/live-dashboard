{
  "configVersion": "v3",
  "app": {
    "appType": "app",
    "version": {
      "code": 2,
      "name": "0.2.0"
    },
    "appId": 20001,
    "appName": "Live Watch",
    "icon": "icon.png",
    "vender": "zepp",
    "description": "Watch health data sync agent for Live Dashboard"
  },
  "runtime": {
    "apiVersion": {
      "compatible": "4.0",
      "target": "4.0",
      "minVersion": "4.0"
    }
  },
  "targets": {
    "gt": {
      "module": {
        "page": {
          "pages": ["page/index"]
        },
        "app-service": {
          "services": ["app-service/live-watch"]
        },
        "app-side": {
          "path": "side-service"
        },
        "setting": {
          "path": "setting/index"
        },
        "app-event": {
          "path": "app-service/live-watch"
        }
      },
      "platforms": [
        { "st": "r", "dw": 480 },
        { "st": "s", "dw": 390 }
      ],
      "designWidth": 480
    }
  },
  "permissions": [
    "device:os.alarm",
    "device:os.ble",
    "device:os.local_storage",
    "data:user.hd.heart_rate",
    "data:user.hd.spo2",
    "data:user.hd.body_temp",
    "data:user.hd.step",
    "data:user.hd.sleep",
    "event:os.health.sleep_status"
  ],
  "i18n": {
    "en-US": {
      "name": "Live Watch"
    },
    "zh-CN": {
      "name": "Live 手表"
    }
  },
  "defaultLanguage": "zh-CN"
}
