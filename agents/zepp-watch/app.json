{
  "configVersion": "v3",
  "app": {
    "appId": 2330101,
    "appName": "LiveDashboard",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "0.1.0"
    },
    "icon": "icon.png",
    "vender": "live-dashboard",
    "description": "Low-power Live Dashboard companion"
  },
  "permissions": [
    "data:os.device.info",
    "data:user.hd.heart_rate",
    "data:user.hd.spo2",
    "data:user.hd.sleep",
    "data:user.hd.stand",
    "data:user.hd.step",
    "data:user.hd.stress",
    "data:user.hd.body_temp",
    "data:user.hd.calorie",
    "device:os.barometer",
    "event:os.health.sleep_status",
    "event:os.health.wear_status",
    "event:os.system.sleep_mode",
    "device:os.local_storage"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "3.0",
      "target": "3.0",
      "minVersion": "3.0"
    }
  },
  "debug": false,
  "targets": {
    "gt": {
      "module": {
        "page": {
          "pages": [
            "page/common/home/index.page"
          ]
        },
        "app-side": {
          "path": "app-side/index"
        },
        "app-service": {
          "services": [
            "app-service/system_event_service"
          ]
        },
        "app-event": {
          "path": "app-service/system_event_service"
        },
        "setting": {
          "path": "setting/index"
        }
      },
      "platforms": [
        { "st": "r", "dw": 480 },
        { "st": "s", "dw": 390 }
      ]
    }
  },
  "i18n": {
    "en-US": { "appName": "Live Dashboard", "name": "Live Dashboard" },
    "zh-CN": { "appName": "活动仪表板", "name": "活动仪表板" }
  },
  "defaultLanguage": "zh-CN"
}
