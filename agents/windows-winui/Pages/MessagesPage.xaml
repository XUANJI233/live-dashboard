<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LiveDashboardAgent.Pages.MessagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:LiveDashboardAgent.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="6">
                <TextBlock Text="消息" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock x:Name="MessageCountText" Text="最近私聊历史" Style="{StaticResource PageSubtitleTextStyle}" />
            </StackPanel>
            <Button x:Name="RefreshButton" Grid.Column="1" Click="Refresh_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="刷新" />
                </StackPanel>
            </Button>
        </Grid>

        <InfoBar
            x:Name="StatusBar"
            Grid.Row="1"
            IsOpen="False"
            IsClosable="True" />

        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="260" />
                <ColumnDefinition Width="3*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <ListView
                        x:Name="MessagesList"
                        ItemsSource="{x:Bind Messages, Mode=OneWay}"
                        SelectionChanged="MessagesList_SelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:MessageDisplayItem">
                                <Grid Padding="2,10" RowSpacing="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Text="{x:Bind Sender}"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind CreatedAtShort}"
                                        FontSize="12"
                                        Opacity="0.66" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Text="{x:Bind Preview}"
                                        Opacity="0.72"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel
                        x:Name="EmptyState"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                        <FontIcon Glyph="&#xE715;" FontSize="28" Opacity="0.72" />
                        <TextBlock Text="暂无消息" FontSize="18" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <ScrollViewer>
                        <StackPanel x:Name="DetailPanel" Spacing="14">
                            <TextBlock
                                x:Name="DetailSenderText"
                                FontSize="22"
                                FontWeight="SemiBold"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                x:Name="DetailMetaText"
                                Style="{StaticResource MutedTextStyle}" />
                            <TextBlock
                                x:Name="DetailBodyText"
                                IsTextSelectionEnabled="True"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel
                        x:Name="DetailEmptyState"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                        <FontIcon Glyph="&#xE8A5;" FontSize="28" Opacity="0.72" />
                        <TextBlock Text="选择一条消息" FontSize="18" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
