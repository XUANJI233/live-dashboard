<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LiveDashboardAgent.Pages.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="{StaticResource PagePadding}" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="6">
                <TextBlock Text="概览" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock Text="Windows Agent" Style="{StaticResource PageSubtitleTextStyle}" />
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="状态" Style="{StaticResource CardTitleTextStyle}" />
                        <TextBlock x:Name="RuntimeStatusText" FontSize="30" FontWeight="SemiBold" />
                        <TextBlock x:Name="CurrentTargetText" Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="连接" Style="{StaticResource CardTitleTextStyle}" />
                        <TextBlock x:Name="ServerText" FontSize="18" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock x:Name="AutostartText" Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock Text="安装" Style="{StaticResource CardTitleTextStyle}" />
                            <TextBlock x:Name="DistributionText" FontSize="18" />
                            <TextBlock x:Name="InstallDirectoryText" Style="{StaticResource MutedTextStyle}" />
                            <TextBlock x:Name="CommandLineText" Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="刷新" Click="Refresh_Click" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
