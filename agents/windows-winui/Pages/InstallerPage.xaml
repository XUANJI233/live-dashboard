<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LiveDashboardAgent.Pages.InstallerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="42" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <InfoBar
            x:Name="StatusBar"
            IsOpen="False"
            IsClosable="True" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="18">
            <Image Source="Assets/Square150x150Logo.scale-200.png" Width="72" Height="72" />
            <StackPanel Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="安装 Live Dashboard Agent" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock
                    Text="选择安装范围和路径。安装会写入清单与 SHA-256 校验，卸载只删除本应用文件。"
                    Style="{StaticResource PageSubtitleTextStyle}" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <Border.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="12" />
                </TransitionCollection>
            </Border.Transitions>
            <StackPanel Spacing="18">
                <Grid ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ComboBox
                        x:Name="InstallScopeBox"
                        Header="安装范围"
                        SelectedIndex="0"
                        SelectionChanged="InstallScope_SelectionChanged"
                        HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="当前用户" Tag="current-user" />
                        <ComboBoxItem Content="所有用户" Tag="all-users" />
                    </ComboBox>

                        <TextBox
                            x:Name="InstallPathBox"
                            Grid.Column="1"
                            Header="安装路径"
                            PlaceholderText="选择父目录后会自动追加 LiveDashboardAgent"
                            TextChanged="InstallPath_TextChanged" />

                        <Button
                            x:Name="BrowsePathButton"
                            Grid.Column="2"
                            Content="选择父目录"
                            Click="BrowsePath_Click"
                            VerticalAlignment="Bottom" />

                    <Button
                        x:Name="DefaultPathButton"
                        Grid.Column="3"
                        Content="默认路径"
                        Click="DefaultPath_Click"
                        VerticalAlignment="Bottom" />

                    <TextBlock
                        x:Name="InstallHintText"
                        Grid.Row="1"
                        Grid.ColumnSpan="4"
                        Style="{StaticResource MutedTextStyle}" />
                </Grid>

                <CheckBox
                    x:Name="DesktopShortcutCheck"
                    Content="创建桌面快捷方式"
                    IsChecked="True" />

                <CheckBox
                    x:Name="LaunchAfterInstallCheck"
                    Content="安装后启动"
                    IsChecked="True" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressRing
                x:Name="BusyRing"
                Width="24"
                Height="24"
                IsActive="False"
                HorizontalAlignment="Left"
                VerticalAlignment="Center" />

            <Button
                x:Name="OpenInstalledButton"
                Grid.Column="1"
                Content="打开已安装版本"
                Click="OpenInstalled_Click"
                Visibility="Collapsed" />

            <Button
                Grid.Column="2"
                Content="退出"
                Click="Close_Click" />

            <Button
                x:Name="InstallButton"
                Grid.Column="3"
                Content="安装"
                Click="Install_Click"
                Style="{StaticResource AccentButtonStyle}" />
        </Grid>
    </Grid>
</Page>
